{
  "manifest_version": 3,
  "name": "AI Studio Pro",
  "version": "3.0.0",
  "description": "Premium AI assistant suite for ChatGPT and Gemini.",
  "permissions": ["storage", "downloads"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*", "https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
